# Database Configuration
DB_HOST=localhost:3306
DB_NAME=honda_dealership
DB_USERNAME=root
DB_PASSWORD=

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-here-min-256-bits
JWT_ACCESS_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Server Configuration
SERVER_PORT=8080
SERVER_CONTEXT_PATH=/honda

# JPA Configuration (update/validate/none)
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false

# Seed Configuration
SEED_ENABLED=true
SEED_ADMIN_EMAIL=admin@honda.com
SEED_ADMIN_PASSWORD=Admin@123
SEED_STAFF_EMAIL=staff@honda.com
SEED_STAFF_PASSWORD=Staff@123

# Cloudinary Configuration (replace with your credentials)
CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name