{
  "info": {
    "name": "Honda Dealership API",
    "description": "Motorbike E-commerce Platform Backend APIs\n\nAuthentication:\n- Login: Returns accessToken + refreshToken\n- Access Token: 15 minutes\n- Refresh Token: 7 days\n\nStandard Response Format:\n```json\n{\n  \"code\": 1000,\n  \"message\": \"Success\",\n  \"result\": {}\n}\n```",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/honda",
      "type": "string"
    },
    {
      "key": "adminEmail",
      "value": "admin@honda.com",
      "type": "string"
    },
    {
      "key": "adminPassword",
      "value": "Admin@123",
      "type": "string"
    },
    {
      "key": "staffEmail",
      "value": "staff@honda.com",
      "type": "string"
    },
    {
      "key": "staffPassword",
      "value": "Staff@123",
      "type": "string"
    },
    {
      "key": "customerEmail",
      "value": "customer@test.com",
      "type": "string"
    },
    {
      "key": "customerPassword",
      "value": "Customer@123",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Login - Admin",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/login",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"{{adminEmail}}\", \"password\": \"{{adminPassword}}\"}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var jsonData = pm.response.json();",
                  "  if (jsonData.result && jsonData.result.accessToken) {",
                  "    pm.environment.set('adminToken', jsonData.result.accessToken);",
                  "    pm.environment.set('adminRefreshToken', jsonData.result.refreshToken);",
                  "    pm.environment.set('userId', jsonData.result.id);",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login - Staff",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/login",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"{{staffEmail}}\", \"password\": \"{{staffPassword}}\"}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var jsonData = pm.response.json();",
                  "  if (jsonData.result && jsonData.result.accessToken) {",
                  "    pm.environment.set('staffToken', jsonData.result.accessToken);",
                  "    pm.environment.set('staffRefreshToken', jsonData.result.refreshToken);",
                  "    pm.environment.set('userId', jsonData.result.id);",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login - Customer",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/login",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"{{customerEmail}}\", \"password\": \"{{customerPassword}}\"}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var jsonData = pm.response.json();",
                  "  if (jsonData.result && jsonData.result.accessToken) {",
                  "    pm.environment.set('customerToken', jsonData.result.accessToken);",
                  "    pm.environment.set('customerRefreshToken', jsonData.result.refreshToken);",
                  "    pm.environment.set('userId', jsonData.result.id);",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Register Customer",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/register",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"newcustomer@test.com\", \"password\": \"Test@123\", \"fullName\": \"New Customer\", \"phone\": \"0912345678\"}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/refresh",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"refreshToken\": \"{{customerRefreshToken}}\"}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var jsonData = pm.response.json();",
                  "  if (jsonData.result && jsonData.result.accessToken) {",
                  "    pm.environment.set('customerToken', jsonData.result.accessToken);",
                  "    pm.environment.set('customerRefreshToken', jsonData.result.refreshToken);",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/logout",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"refreshToken\": \"{{customerRefreshToken}}\"}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/auth/me",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "2. Products (Public)",
      "item": [
        {
          "name": "Get All Motorcycles",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/motorcycles"
          }
        },
        {
          "name": "Get Motorcycle Detail",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/motorcycles/{{motorcycleId}}"
          }
        },
        {
          "name": "Get Motorcycle by Slug",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/motorcycles/slug/honda-vision-2026"
          }
        },
        {
          "name": "Get Brands",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/brands"
          }
        },
        {
          "name": "Get Categories",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/categories"
          }
        }
      ]
    },
    {
      "name": "3. Admin Products",
      "item": [
        {
          "name": "Create Motorcycle",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/admin/motorcycles",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"Honda Lead 2026\", \"slug\": \"honda-lead-2026\", \"description\": \"Premium scooter\", \"price\": 45000000, \"brandId\": 1, \"categoryIds\": [1]}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  var jsonData = pm.response.json();",
                  "  if (jsonData.result && jsonData.result.id) {",
                  "    pm.environment.set('motorcycleId', jsonData.result.id);",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Motorcycle",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/v1/admin/motorcycles/{{motorcycleId}}",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"Honda Lead 2026 Updated\", \"price\": 48000000}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Delete Motorcycle",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v1/admin/motorcycles/{{motorcycleId}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ]
          }
        },
        {
          "name": "Create Variant",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/admin/variants",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"motorcycleId\": {{motorcycleId}}, \"color\": \"Blue\", \"stockQuantity\": 5}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  var jsonData = pm.response.json();",
                  "  if (jsonData.result && jsonData.result.id) {",
                  "    pm.environment.set('variantId', jsonData.result.id);",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Brand",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/admin/brands",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"Kawasaki\", \"description\": \"Kawasaki motorcycles\"}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Create Category",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/admin/categories",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"Xe điện\", \"slug\": \"xe-dien\", \"description\": \"Xe máy điện\"}",
              "options": { "raw": { "language": "json" } }
            }
          }
        }
      ]
    },
    {
      "name": "4. Cart",
      "item": [
        {
          "name": "Add To Cart",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/cart/items",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"variantId\": {{variantId}}, \"quantity\": 2}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  var jsonData = pm.response.json();",
                  "  if (jsonData.result && jsonData.result.id) {",
                  "    pm.environment.set('cartItemId', jsonData.result.id);",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get My Cart",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/cart",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ]
          }
        },
        {
          "name": "Update Cart Item",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/v1/cart/items/{{cartItemId}}",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"quantity\": 3}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Remove Cart Item",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v1/cart/items/{{cartItemId}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ]
          }
        },
        {
          "name": "Clear Cart",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v1/cart/clear",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "5. Orders (Customer)",
      "item": [
        {
          "name": "Checkout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/orders/checkout",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"paymentMethod\": \"COD\"}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  var jsonData = pm.response.json();",
                  "  if (jsonData.result && jsonData.result.id) {",
                  "    pm.environment.set('orderId', jsonData.result.id);",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get My Orders",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/orders/my-orders",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ]
          }
        },
        {
          "name": "Get Order Detail",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/orders/{{orderId}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ]
          }
        },
        {
          "name": "Cancel Order",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/v1/orders/{{orderId}}/cancel",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "6. Staff Orders",
      "item": [
        {
          "name": "Get All Orders",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/staff/orders",
            "header": [
              { "key": "Authorization", "value": "Bearer {{staffToken}}" }
            ]
          }
        },
        {
          "name": "Get Order Detail",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/staff/orders/{{orderId}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{staffToken}}" }
            ]
          }
        },
        {
          "name": "Confirm Order",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/v1/staff/orders/{{orderId}}/confirm",
            "header": [
              { "key": "Authorization", "value": "Bearer {{staffToken}}" }
            ]
          }
        },
        {
          "name": "Preparing Order",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/v1/staff/orders/{{orderId}}/preparing",
            "header": [
              { "key": "Authorization", "value": "Bearer {{staffToken}}" }
            ]
          }
        },
        {
          "name": "Shipping Order",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/v1/staff/orders/{{orderId}}/shipping",
            "header": [
              { "key": "Authorization", "value": "Bearer {{staffToken}}" }
            ]
          }
        },
        {
          "name": "Delivered Order",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/v1/staff/orders/{{orderId}}/delivered",
            "header": [
              { "key": "Authorization", "value": "Bearer {{staffToken}}" }
            ]
          }
        },
        {
          "name": "Cancel Order",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/v1/staff/orders/{{orderId}}/cancel",
            "header": [
              { "key": "Authorization", "value": "Bearer {{staffToken}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "7. Admin Dashboard",
      "item": [
        {
          "name": "Get Summary",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/admin/dashboard/summary",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ]
          }
        },
        {
          "name": "Get Revenue",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/admin/dashboard/revenue?range=7days",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ]
          }
        },
        {
          "name": "Get Top Products",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/admin/dashboard/top-products",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ]
          }
        },
        {
          "name": "Get Order Status",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/admin/dashboard/order-status",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ]
          }
        }
      ]
    }
  ]
}