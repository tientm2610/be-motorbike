              "raw": "{\n  \"shippingName\": \"John Doe\",\n  \"shippingPhone\": \"0123456789\",\n  \"shippingAddress\": \"123 Main Street, District 1, Ho Chi Minh City\",\n  \"paymentMethod\": \"CASH\",\n  \"note\": \"Please deliver in the morning\"\n}"
