{
  "info": {
    "name": "Honda Dealership API",
    "description": "Complete API collection for Honda Dealership E-commerce Backend\n\n## Base URL\n```\n{{baseUrl}}\n```\n\n## Standard Response Format\n```json\n{\n  \"code\": 1000,\n  \"message\": \"Success\",\n  \"result\": {}\n}\n```\n\n## Authentication\nThis collection uses Bearer token authentication. After logging in, the access token is automatically saved to the environment variable `accessToken`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/honda/api/v1",
      "type": "string"
    },
    {
      "key": "adminBaseUrl",
      "value": "http://localhost:8080/honda/api",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "refreshToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "adminEmail",
      "value": "admin@honda.com",
      "type": "string"
    },
    {
      "key": "adminPassword",
      "value": "Admin@123",
      "type": "string"
    },
    {
      "key": "staffEmail",
      "value": "staff@honda.com",
      "type": "string"
    },
    {
      "key": "staffPassword",
      "value": "Staff@123",
      "type": "string"
    },
    {
      "key": "customerEmail",
      "value": "customer@example.com",
      "type": "string"
    },
    {
      "key": "customerPassword",
      "value": "Customer@123",
      "type": "string"
    },
    {
      "key": "motorcycleId",
      "value": "",
      "type": "string"
    },
    {
      "key": "variantId",
      "value": "",
      "type": "string"
    },
    {
      "key": "orderId",
      "value": "",
      "type": "string"
    },
    {
      "key": "imageId",
      "value": "",
      "type": "string"
    },
    {
      "key": "brandId",
      "value": "",
      "type": "string"
    },
    {
      "key": "categoryId",
      "value": "",
      "type": "string"
    },
    {
      "key": "cartItemId",
      "value": "",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "javascript",
        "exec": [
          "if (pm.request.headers.has('Authorization')) {",
          "  // Already has auth header",
          "} else if (pm.request.url.path.includes('/auth/login') || pm.request.url.path.includes('/auth/register') || pm.request.url.path.includes('/auth/refresh')) {",
          "  // Skip auth for auth endpoints",
          "} else if (pm.request.url.path.includes('/products') || pm.request.url.path.includes('/brands') || pm.request.url.path.includes('/categories') || pm.request.url.path.includes('/variants')) {",
          "  // Skip auth for public product endpoints",
          "} else if (pm.request.url.path.includes('/health')) {",
          "  // Skip auth for health check",
          "} else {",
          "  pm.request.headers.add({key: 'Authorization', value: 'Bearer ' + pm.environment.get('accessToken')});",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "1. Authentication",
      "item": [
        {
          "name": "POST Register (Customer)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{customerEmail}}\",\n  \"password\": \"{{customerPassword}}\",\n  \"fullName\": \"Test Customer\",\n  \"phone\": \"0123456789\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201 or 200', function() {",
                  "    pm.expect(pm.response.status).to.be.oneOf([201, 200]);",
                  "});",
                  "pm.test('Response has code', function() {",
                  "    pm.expect(pm.response.json()).to.have.property('code');",
                  "});",
                  "pm.test('Response has result', function() {",
                  "    pm.expect(pm.response.json()).to.have.property('result');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST Login (Admin)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function() {",
                  "    pm.expect(pm.response.status).to.equal(200);",
                  "});",
                  "pm.test('Login successful', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.result).to.have.property('accessToken');",
                  "});",
                  "pm.test('Save access token', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('accessToken', jsonData.result.accessToken);",
                  "});",
                  "pm.test('Save refresh token', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('refreshToken', jsonData.result.refreshToken);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST Login (Staff)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{staffEmail}}\",\n  \"password\": \"{{staffPassword}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function() {",
                  "    pm.expect(pm.response.status).to.equal(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST Login (Customer)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{customerEmail}}\",\n  \"password\": \"{{customerPassword}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function() {",
                  "    pm.expect(pm.response.status).to.equal(200);",
                  "});",
                  "pm.test('Save access token', function() {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.result && jsonData.result.accessToken) {",
                  "        pm.environment.set('accessToken', jsonData.result.accessToken);",
                  "        pm.environment.set('refreshToken', jsonData.result.refreshToken);",
                  "    }",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/refresh",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function() {",
                  "    pm.expect(pm.response.status).to.equal(200);",
                  "});",
                  "pm.test('Save new access token', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('accessToken', jsonData.result.accessToken);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST Logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/logout",
            "header": [
              {
                "key": "Content-Type",
