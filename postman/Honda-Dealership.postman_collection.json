                  "    pm.expect(pm.response.status).to.equal(200);",
                  "});",
                  "pm.test('Clear tokens', function() {",
                  "    pm.environment.set('accessToken', '');",
                  "    pm.environment.set('refreshToken', '');",
                  "});"
                ]
              }
            }
          ]
        },
